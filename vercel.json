{
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/c/:slug",
      "destination": "https://foreas-stripe-backend-production.up.railway.app/c/:slug"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
